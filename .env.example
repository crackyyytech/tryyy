# Database - Get from Vercel Dashboard → Storage → Create Database (Postgres)
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# JWT Secret - Generate a strong random string
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters

# Vercel Blob - Get from Vercel Dashboard → Storage → Create Blob Store
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxx

# Frontend API Base URL - Keep as /api for production on Vercel
VITE_API_BASE_URL=/api
